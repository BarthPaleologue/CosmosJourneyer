# Load this file explicitly with: source .env
# Variables passed before a deployment command then take precedence.

# VPS connection
export VPS_HOST=example.com
export VPS_USERNAME=deploy
export VPS_SSH_PORT=22

# Remote deployment paths
export VPS_GAME_PATH=/var/www/cosmos_journeyer/game
export VPS_WEBSITE_PATH=/var/www/cosmos_journeyer/website

# Optional deployment behavior
export DEPLOY_DRY_RUN=true
