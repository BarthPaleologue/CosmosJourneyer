{
    "name": "terrain-generation",
    "version": "1.8.0",
    "private": false,
    "description": "Rust-powered terrain generation for Cosmos Journeyer compiled to WebAssembly for fast planetary rendering.",
    "keywords": [
        "cosmos-journeyer",
        "procedural-generation",
        "rust",
        "terrain",
        "wasm"
    ],
    "homepage": "https://cosmosjourneyer.com",
    "bugs": {
        "url": "https://github.com/BarthPaleologue/CosmosJourneyer/issues",
        "email": "barth.paleologue@cosmosjourneyer.com"
    },
    "license": "Apache-2.0",
    "author": {
        "name": "Barthélemy Paléologue",
        "email": "barth.paleologue@cosmosjourneyer.com",
        "url": "https://barth.paleologue.fr"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/BarthPaleologue/CosmosJourneyer"
    },
    "files": [
        "pkg",
        "src",
        "Cargo.toml",
        "Cargo.lock",
        "README.md",
        "LICENSE"
    ],
    "type": "module",
    "sideEffects": [
        "./pkg/terrain_generation.js",
        "./pkg/snippets/*"
    ],
    "module": "./pkg/terrain_generation.js",
    "types": "./pkg/terrain_generation.d.ts",
    "exports": {
        ".": {
            "types": "./pkg/terrain_generation.d.ts",
            "import": "./pkg/terrain_generation.js"
        }
    },
    "scripts": {
        "build": "wasm-pack build --release --out-dir pkg --target bundler --out-name terrain_generation",
        "format": "cargo fmt",
        "format:check": "cargo fmt --check",
        "lint": "cargo clippy --all-targets --all-features -- -D warnings",
        "test:unit": "cargo test"
    }
}
