{
    "name": "@cosmos-journeyer/game",
    "version": "1.11.0-dev",
    "private": true,
    "description": "Cosmos Journeyer is a space exploration game featuring fully explorable planets, across millions of star systems. It is built using Babylon.JS, and a lot of passion.",
    "keywords": [
        "babylonjs",
        "exploration",
        "game",
        "procedural-generation",
        "space",
        "webgl",
        "webgpu"
    ],
    "homepage": "https://cosmosjourneyer.com",
    "bugs": {
        "url": "https://github.com/BarthPaleologue/CosmosJourneyer/issues",
        "email": "barth.paleologue@cosmosjourneyer.com"
    },
    "license": "AGPL-3.0-only",
    "author": {
        "name": "Barthélemy Paléologue",
        "email": "barth.paleologue@cosmosjourneyer.com",
        "url": "https://barth.paleologue.fr"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/BarthPaleologue/CosmosJourneyer"
    },
    "type": "module",
    "scripts": {
        "build": "rspack --mode=production --node-env=production --configLoader=native",
        "build:watch": "rspack --watch --mode=development --configLoader=native",
        "serve": "rspack serve --configLoader=native",
        "serve:prod": "http-server dist -p 8080",
        "format:check": "oxfmt . --check",
        "format": "oxfmt . --write",
        "test:unit": "vitest run",
        "test:e2e": "pnpm build && playwright test",
        "test:e2e:update": "pnpm build && playwright test --update-snapshots",
        "doc": "typedoc --options typedoc.json",
        "serve:doc": "http-server doc -p 8081",
        "lint": "eslint .",
        "typecheck:watch": "tsc --noEmit --watch",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@babylonjs/core": "^8.48.0",
        "@babylonjs/gui": "^8.48.0",
        "@babylonjs/havok": "^1.3.11",
        "@babylonjs/inspector": "^8.48.0",
        "@babylonjs/loaders": "^8.48.0",
        "@babylonjs/materials": "^8.48.0",
        "@babylonjs/node-editor": "^8.48.0",
        "@brianchirls/game-input": "^0.1.1",
        "@cosmos-journeyer/physics": "workspace:^",
        "@cosmos-journeyer/universe-model": "workspace:^",
        "babylonjs-shading-language": "workspace:^",
        "d3": "^7.9.0",
        "earcut": "^3.0.2",
        "extended-random": "^1.2.2",
        "fast-simplex-noise": "^4.0.0",
        "i18next": "^26.0.8",
        "qrcode": "^1.5.4",
        "squirrel-noise": "^1.0.0",
        "terrain-generation": "workspace:^",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@playwright/test": "^1.59.1",
        "@rspack/cli": "^2.0.1",
        "@rspack/core": "^2.0.1",
        "@rspack/dev-server": "^2.0.1",
        "@tauri-apps/cli": "^2.11.0",
        "@types/d3": "^7.4.3",
        "@types/earcut": "^3.0.0",
        "@types/qrcode": "^1.5.6",
        "@types/webpack": "^5.28.5",
        "@types/webpack-env": "^1.18.8",
        "eslint": "catalog:",
        "http-server": "catalog:",
        "jsdom": "^29.1.1",
        "oxfmt": "catalog:",
        "selfsigned": "^5.5.0",
        "ts-checker-rspack-plugin": "^1.3.0",
        "ts-shader-loader": "^2.1.0",
        "typedoc": "catalog:",
        "typedoc-github-theme": "catalog:",
        "typedoc-plugin-missing-exports": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    }
}
