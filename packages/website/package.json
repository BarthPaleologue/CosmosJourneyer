{
    "name": "@cosmos-journeyer/website",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint . --max-warnings=0",
        "lint:fix": "eslint . --max-warnings=0 --fix",
        "format": "oxfmt . --write",
        "format:check": "oxfmt . --check",
        "typecheck": "tsc --noEmit",
        "typecheck:watch": "tsc --noEmit --watch",
        "test:all": "pnpm lint && pnpm typecheck && pnpm build",
        "serve:prod": "http-server out"
    },
    "dependencies": {
        "next": "^16.2.6",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "sass": "^1.99.0",
        "sharp": "^0.34.5"
    },
    "devDependencies": {
        "@types/node": "^25.5.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "eslint": "catalog:",
        "http-server": "catalog:",
        "oxfmt": "catalog:",
        "typescript": "catalog:"
    }
}
