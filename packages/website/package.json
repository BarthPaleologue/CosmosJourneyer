{
    "name": "@cosmos-journeyer/website",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "http-server out",
        "lint": "eslint . --max-warnings=0",
        "lint:fix": "eslint . --max-warnings=0 --fix",
        "format": "oxfmt . --write",
        "format:check": "oxfmt . --check",
        "typecheck": "tsc --noEmit",
        "typecheck:watch": "tsc --noEmit --watch",
        "test:all": "pnpm build && pnpm lint && pnpm typecheck"
    },
    "dependencies": {
        "next": "^16.2.9",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "sharp": "^0.35.2"
    },
    "devDependencies": {
        "@types/node": "^26.0.1",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "eslint": "catalog:",
        "http-server": "catalog:",
        "oxfmt": "catalog:",
        "typescript": "catalog:"
    }
}
