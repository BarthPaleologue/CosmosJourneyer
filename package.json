{
    "name": "cosmos-journeyer",
    "version": "1.11.0-dev",
    "private": true,
    "engines": {
        "node": ">=18.0.0",
        "pnpm": ">=8.0.0"
    },
    "description": "Cosmos Journeyer is a space exploration game featuring fully explorable planets, across millions of star systems. It is built using Babylon.JS, and a lot of passion.",
    "homepage": "https://cosmosjourneyer.com",
    "author": {
        "name": "Barthélemy Paléologue",
        "email": "barth.paleologue@cosmosjourneyer.com",
        "url": "https://barth.paleologue.fr"
    },
    "license": "AGPL-3.0-only",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "https://github.com/BarthPaleologue/CosmosJourneyer"
    },
    "bugs": {
        "url": "https://github.com/BarthPaleologue/CosmosJourneyer/issues",
        "email": "barth.paleologue@cosmosjourneyer.com"
    },
    "keywords": [
        "space",
        "game",
        "exploration",
        "babylonjs",
        "procedural-generation",
        "webgl",
        "webgpu"
    ],
    "scripts": {
        "build": "pnpm build:game",
        "build:game": "rspack --config packages/game/rspack.config.js --mode=production --node-env=production",
        "build:black-hole-demo": "rspack --config packages/black-hole-demo/rspack.config.js --mode=production --node-env=production",
        "build:playground": "pnpm --filter @cosmos-journeyer/playground build",
        "build:prod": "pnpm build:game && pnpm build:playground && pnpm build:black-hole-demo && pnpm doc && node scripts/build-deploy.mjs",
        "serve": "pnpm serve:game",
        "serve:game": "rspack serve --config packages/game/rspack.config.js",
        "serve:black-hole-demo": "rspack serve --config packages/black-hole-demo/rspack.config.js",
        "serve:playground": "pnpm --filter @cosmos-journeyer/playground serve",
        "serve:prod": "http-server dist -p 8080",
        "format:check": "prettier . --check",
        "format": "prettier . --write",
        "test:unit": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "pnpm --filter @cosmos-journeyer/playground test:e2e",
        "test:e2e:update": "pnpm --filter @cosmos-journeyer/playground test:e2e:update",
        "test:e2e:docker": "pnpm --filter @cosmos-journeyer/playground test:e2e:docker",
        "test:e2e:docker:update": "pnpm --filter @cosmos-journeyer/playground test:e2e:docker:update",
        "doc": "typedoc --options typedoc.json",
        "serve:doc": "http-server doc -p 8081",
        "lint": "eslint .",
        "lint:fast": "eslint . --rule \"import/no-cycle: 0\" --rule \"import/namespace: 0\" --cache",
        "typecheck:watch": "tsc --noEmit --watch",
        "typecheck": "tsc --noEmit",
        "prepare": "husky"
    },
    "devDependencies": {
        "@eslint/js": "^9.35.0",
        "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
        "@playwright/test": "^1.55.0",
        "@rspack/cli": "^1.5.3",
        "@rspack/core": "^1.5.3",
        "@tauri-apps/cli": "^2.8.4",
        "@types/d3": "^7.4.3",
        "@types/webpack": "^5.28.5",
        "@types/webpack-env": "^1.18.8",
        "@vitest/coverage-v8": "^3.2.4",
        "eslint": "^9.35.0",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "globals": "^16.4.0",
        "html-loader": "^5.1.0",
        "html-webpack-plugin": "^5.6.4",
        "http-server": "^14.1.1",
        "husky": "^9.1.7",
        "jsdom": "^26.1.0",
        "lint-staged": "^16.1.6",
        "prettier": "^3.6.2",
        "raw-loader": "^4.0.2",
        "sass": "^1.92.1",
        "sass-loader": "^16.0.5",
        "ts-checker-rspack-plugin": "^1.1.5",
        "ts-node": "^10.9.2",
        "ts-shader-loader": "^2.0.2",
        "typedoc": "^0.28.12",
        "typedoc-github-theme": "^0.3.1",
        "typedoc-plugin-missing-exports": "^4.1.0",
        "typescript": "^5.9.2",
        "typescript-eslint": "^8.43.0",
        "vite-tsconfig-paths": "^5.1.4",
        "vitest": "^3.2.4"
    },
    "lint-staged": {
        "*": "prettier --write --ignore-unknown"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "husky"
        ]
    }
}
